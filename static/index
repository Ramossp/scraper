<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>W.S.T.B — Tennant Scraper</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Bebas+Neue&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <canvas id="bg-canvas"></canvas>
    <div class="noise-overlay"></div>

    <div class="container">

        <!-- LOGO -->
        <header class="site-header fade-in-logo">
            <div class="logo-lockup">
                <div class="logo-icon">
                    <img src="data:image/png;base64," alt="Tennant" style="height:56px; width:auto; filter: drop-shadow(0 0 8px rgba(0,200,255,0.4));"/>
                </div>
            </div>
            <div style="display:flex;gap:10px;align-items:center;">
                <a href="{{ url_for('tennix') }}" class="manual-pill" style="background:rgba(0,73,144,0.08);border-color:rgba(0,73,144,0.22);color:#004990;">
                    <i class="fa-solid fa-robot"></i>
                    TENNIX IA
                </a>
                <a href="{{ url_for('pesquisar') }}" class="manual-pill" style="background:rgba(0,204,255,0.07);border-color:rgba(0,204,255,0.18);color:var(--cyan);">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    Pesquisar
                </a>
                <a href="{{ url_for('manual') }}" target="_blank" class="manual-pill">
                    <i class="fa-regular fa-book-open"></i>
                    Manual
                </a>
            </div>
        </header>

        <main class="fade-in-content">

            <!-- HERO -->
            <div class="hero-section">
                <div class="hero-badge">
                    <span class="live-dot"></span>
                    Sistema operacional
                </div>
                <h1 class="hero-title">Scraper de<br><span class="gradient-text">Artigos</span></h1>
                <p class="hero-desc">Extração e tradução automática de conteúdo dos blogs oficiais Tennant em qualquer idioma.</p>
            </div>

            <!-- FORMULÁRIO -->
            <div class="glass-card">
                <form id="scraper-form">

                    <div class="field-group">
                        <label for="pais" class="field-label">
                            <i class="fa-solid fa-earth-americas"></i>
                            País de origem
                        </label>
                        <div class="select-wrap">
                            <select id="pais" name="pais" required></select>
                            <i class="fa-solid fa-chevron-down select-arrow"></i>
                        </div>
                    </div>

                    <div class="field-row">
                        <div class="field-group" style="flex:1">
                            <label for="quantidade" class="field-label">
                                <i class="fa-regular fa-file-lines"></i>
                                Quantidade
                            </label>
                            <div class="number-wrap">
                                <input type="number" id="quantidade" name="quantidade" min="1" max="50" value="1" required>
                                <div class="number-ctrl">
                                    <button type="button" class="num-btn" onclick="nudge(1)"><i class="fa-solid fa-chevron-up"></i></button>
                                    <button type="button" class="num-btn" onclick="nudge(-1)"><i class="fa-solid fa-chevron-down"></i></button>
                                </div>
                                <span class="num-max">/ 50</span>
                            </div>
                        </div>
                        <div class="field-meta">
                            <div class="meta-item"><i class="fa-solid fa-clock-rotate-left"></i> Fila ativa</div>
                            <div class="meta-item"><i class="fa-solid fa-file-word"></i> Saída .docx</div>
                        </div>
                    </div>

                    <div id="aviso-quantidade" class="alert-bar" style="display:none;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        Máximo de 50 artigos por execução
                    </div>

                    <button type="submit" id="submit-btn" class="run-btn">
                        <span class="run-btn-inner">
                            <i class="fa-solid fa-bolt"></i>
                            <span>Iniciar processamento</span>
                        </span>
                        <span class="run-btn-shine"></span>
                    </button>

                </form>
            </div>

            <!-- LOADING -->
            <div id="status" class="loading-card" style="display:none;">
                <div class="machine-scene">

                    <svg viewBox="0 0 360 160" xmlns="http://www.w3.org/2000/svg" class="machine-svg">
                        <defs>
                            <linearGradient id="bodyGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" stop-color="#00d8ee"/>
                                <stop offset="100%" stop-color="#008a9e"/>
                            </linearGradient>
                            <linearGradient id="capotGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#00e4f8"/>
                                <stop offset="100%" stop-color="#009db0"/>
                            </linearGradient>
                            <radialGradient id="groundGlow" cx="50%" cy="100%" r="50%">
                                <stop offset="0%" stop-color="#00c8ff" stop-opacity="0.25"/>
                                <stop offset="100%" stop-color="#00c8ff" stop-opacity="0"/>
                            </radialGradient>
                            <filter id="glow">
                                <feGaussianBlur stdDeviation="2.5" result="blur"/>
                                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                            </filter>
                            <filter id="shadow" x="-15%" y="-15%" width="130%" height="130%">
                                <feDropShadow dx="0" dy="6" stdDeviation="5" flood-color="#000" flood-opacity="0.5"/>
                            </filter>
                            <clipPath id="wheelClip1"><circle cx="90" cy="130" r="16"/></clipPath>
                            <clipPath id="wheelClip2"><circle cx="248" cy="130" r="20"/></clipPath>
                        </defs>

                        <!-- CHÃO -->
                        <ellipse cx="170" cy="148" rx="130" ry="9" fill="url(#groundGlow)"/>
                        <rect x="0" y="147" width="360" height="3" rx="1.5" fill="#0d1a26"/>
                        <!-- Marcas do chão -->
                        <g class="ground-strip">
                            <rect x="-10" y="149" width="38" height="2" rx="1" fill="#00c8ff" opacity="0.15"/>
                            <rect x="45"  y="149" width="38" height="2" rx="1" fill="#00c8ff" opacity="0.15"/>
                            <rect x="100" y="149" width="38" height="2" rx="1" fill="#00c8ff" opacity="0.15"/>
                            <rect x="155" y="149" width="38" height="2" rx="1" fill="#00c8ff" opacity="0.15"/>
                            <rect x="210" y="149" width="38" height="2" rx="1" fill="#00c8ff" opacity="0.15"/>
                            <rect x="265" y="149" width="38" height="2" rx="1" fill="#00c8ff" opacity="0.15"/>
                            <rect x="320" y="149" width="38" height="2" rx="1" fill="#00c8ff" opacity="0.15"/>
                        </g>

                        <!-- GRUPO PRINCIPAL (bounce) -->
                        <g class="ride-group" filter="url(#shadow)">

                            <!-- ── MÁQUINA ── -->

                            <!-- Roda dianteira -->
                            <g class="w-front" transform-origin="90 130">
                                <circle cx="90" cy="130" r="16" fill="#0e1e2c" stroke="#1a3045" stroke-width="1.5"/>
                                <circle cx="90" cy="130" r="9"  fill="#152535"/>
                                <circle cx="90" cy="130" r="3.5" fill="#1e3550"/>
                                <line x1="90" y1="114" x2="90" y2="146" stroke="#1e3550" stroke-width="2.5"/>
                                <line x1="74" y1="130" x2="106" y2="130" stroke="#1e3550" stroke-width="2.5"/>
                                <line x1="79" y1="119" x2="101" y2="141" stroke="#1e3550" stroke-width="2"/>
                                <line x1="101" y1="119" x2="79" y2="141" stroke="#1e3550" stroke-width="2"/>
                                <!-- hubcap brilho -->
                                <circle cx="86" cy="127" r="2" fill="rgba(255,255,255,0.12)"/>
                            </g>

                            <!-- Roda traseira -->
                            <g class="w-rear" transform-origin="248 130">
                                <circle cx="248" cy="130" r="20" fill="#0e1e2c" stroke="#1a3045" stroke-width="1.5"/>
                                <circle cx="248" cy="130" r="11" fill="#152535"/>
                                <circle cx="248" cy="130" r="4"  fill="#1e3550"/>
                                <line x1="248" y1="110" x2="248" y2="150" stroke="#1e3550" stroke-width="3"/>
                                <line x1="228" y1="130" x2="268" y2="130" stroke="#1e3550" stroke-width="3"/>
                                <line x1="234" y1="116" x2="262" y2="144" stroke="#1e3550" stroke-width="2.5"/>
                                <line x1="262" y1="116" x2="234" y2="144" stroke="#1e3550" stroke-width="2.5"/>
                                <circle cx="243" cy="126" r="2.5" fill="rgba(255,255,255,0.1)"/>
                            </g>

                            <!-- Saia / base -->
                            <rect x="78" y="112" width="180" height="22" rx="6" fill="#253545"/>
                            <rect x="80" y="114" width="176" height="6" rx="2" fill="#2e4558" opacity="0.8"/>

                            <!-- Capô principal (teal) -->
                            <path d="M88,55 Q93,40 112,38 L225,38 Q248,38 254,58 L268,112 L76,112 Z" fill="url(#bodyGrad)"/>

                            <!-- Reflexo brilhoso no capô -->
                            <path d="M120,43 Q148,40 190,40 L218,40 Q238,41 244,52 L248,70 Q218,58 170,58 Q128,58 116,70 Z" fill="white" opacity="0.14"/>

                            <!-- Faixa lateral decorativa -->
                            <path d="M88,88 L268,88" stroke="rgba(0,232,255,0.3)" stroke-width="1.5" stroke-dasharray="6,4"/>

                            <!-- Grade ventilação -->
                            <g opacity="0.5">
                                <rect x="92"  y="64" width="3" height="30" rx="1.5" fill="#006a78"/>
                                <rect x="99"  y="64" width="3" height="30" rx="1.5" fill="#006a78"/>
                                <rect x="106" y="64" width="3" height="30" rx="1.5" fill="#006a78"/>
                                <rect x="113" y="64" width="3" height="30" rx="1.5" fill="#006a78"/>
                                <rect x="120" y="64" width="3" height="30" rx="1.5" fill="#006a78"/>
                            </g>

                            <!-- Painel cockpit -->
                            <rect x="178" y="50" width="58" height="34" rx="5" fill="#071520" opacity="0.85" stroke="rgba(0,200,255,0.25)" stroke-width="1"/>
                            <!-- Tela do painel -->
                            <rect x="182" y="54" width="24" height="14" rx="2" fill="#001828" stroke="#004466" stroke-width="0.8"/>
                            <rect x="184" y="56" width="20" height="2" rx="1" fill="#00c8ff" opacity="0.5"/>
                            <rect x="184" y="60" width="14" height="2" rx="1" fill="#00c8ff" opacity="0.3"/>
                            <rect x="184" y="64" width="17" height="2" rx="1" fill="#00c8ff" opacity="0.2"/>
                            <!-- LEDs -->
                            <circle cx="214" cy="58" r="3.5" fill="#00e8a2" filter="url(#glow)"/>
                            <circle cx="222" cy="55" r="2.5" fill="#ff3d60" opacity="0.9"/>
                            <circle cx="222" cy="63" r="2.5" fill="#f5c518" opacity="0.9"/>
                            <circle cx="228" cy="59" r="2"   fill="#00c8ff" opacity="0.7"/>

                            <!-- Logo TENNANT -->
                            <ellipse cx="158" cy="78" rx="28" ry="15" fill="#006070" stroke="#00d4e8" stroke-width="1.5"/>
                            <text x="158" y="82" text-anchor="middle" font-family="Arial Black,sans-serif" font-size="7.5" font-weight="900" fill="white" letter-spacing="0.8">TENNANT</text>

                            <!-- S7 label -->
                            <text x="95" y="108" font-family="Arial Black,sans-serif" font-size="15" font-weight="900" fill="white" opacity="0.9">S7</text>

                            <!-- Escova frontal -->
                            <g class="brush" transform-origin="90 131">
                                <circle cx="90" cy="131" r="7" fill="#0a2030" stroke="#00aacc" stroke-width="1.2"/>
                                <line x1="90" y1="124" x2="90" y2="138" stroke="#007faa" stroke-width="2"/>
                                <line x1="83" y1="131" x2="97" y2="131" stroke="#007faa" stroke-width="2"/>
                                <line x1="85" y1="126" x2="95" y2="136" stroke="#007faa" stroke-width="1.5"/>
                                <line x1="95" y1="126" x2="85" y2="136" stroke="#007faa" stroke-width="1.5"/>
                            </g>

                            <!-- Bolhas de limpeza -->
                            <g class="bubbles">
                                <circle class="b1" cx="68" cy="130" r="4"   fill="#00c8ff" opacity="0.7"/>
                                <circle class="b2" cx="58" cy="122" r="2.5" fill="#00e8ff" opacity="0.55"/>
                                <circle class="b3" cx="62" cy="116" r="2"   fill="#00aacc" opacity="0.45"/>
                                <circle class="b4" cx="50" cy="128" r="3"   fill="#00c8ff" opacity="0.4"/>
                                <circle class="b5" cx="54" cy="112" r="1.5" fill="#00e8ff" opacity="0.35"/>
                            </g>

                    </svg>

                    <div class="machine-label">
                        <div class="machine-label-dot"></div>
                        <span id="status-text">Processando artigos</span>
                        <span class="dots"><span>.</span><span>.</span><span>.</span></span>
                    </div>
                </div>
            </div>

            <!-- RESULTADO -->
            <div id="resultado" class="result-panel" style="display:none;">

                <div class="result-header">
                    <div class="result-icon">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <div class="result-text">
                        <div class="result-title">Processamento concluído</div>
                        <div class="result-sub">Seus arquivos estão prontos</div>
                    </div>
                    <div class="result-count" id="result-count">— arquivos</div>
                </div>

                <div id="downloads" class="file-list"></div>

            </div>

        </main>
    </div>

    <script src="{{ url_for('static', filename='script.js') }}"></script>
    <script>
        // Nudge quantity
        function nudge(dir) {
            const inp = document.getElementById('quantidade');
            const v = parseInt(inp.value) + dir;
            if (v >= 1 && v <= 50) inp.value = v;
        }

        // Subtle particle canvas
        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');
        let W, H, particles = [];

        function resize() {
            W = canvas.width  = window.innerWidth;
            H = canvas.height = window.innerHeight;
        }

        function initParticles() {
            particles = Array.from({length: 55}, () => ({
                x: Math.random() * W,
                y: Math.random() * H,
                r: Math.random() * 1.4 + 0.3,
                vx: (Math.random() - 0.5) * 0.22,
                vy: (Math.random() - 0.5) * 0.22,
                o: Math.random() * 0.35 + 0.05
            }));
        }

        function draw() {
            ctx.clearRect(0, 0, W, H);
            for (const p of particles) {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(0,200,255,${p.o})`;
                ctx.fill();
                p.x += p.vx; p.y += p.vy;
                if (p.x < 0) p.x = W;
                if (p.x > W) p.x = 0;
                if (p.y < 0) p.y = H;
                if (p.y > H) p.y = 0;
            }
            requestAnimationFrame(draw);
        }

        resize(); initParticles(); draw();
        window.addEventListener('resize', () => { resize(); initParticles(); });
    </script>
</body>
</html>
