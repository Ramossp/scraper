                    </div>
                </div>
                <div class="aud-prog-bar-wrap">
                    <div class="aud-prog-bar" id="aud-prog-bar" style="width:0%"></div>
                </div>
                <div class="aud-prog-stats">
                    <span><i class="fa-solid fa-check-circle" style="color:var(--ag2)"></i> <span id="aud-ok-count">0</span> completas</span>
                    <span><i class="fa-solid fa-triangle-exclamation" style="color:#e67e22"></i> <span id="aud-warn-count">0</span> com pendências</span>
                    <span><i class="fa-solid fa-circle-xmark" style="color:#e74c3c"></i> <span id="aud-err-count">0</span> sem documentos</span>
